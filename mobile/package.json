{
  "name": "@build-a-job/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 npm exec -- expo start --port 8086",
    "start:clear": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 npm exec -- expo start -c --port 8086",
    "start:offline": "npm exec -- expo start --offline --port 8086",
    "start:with-checks": "npm exec -- expo start --port 8086",
    "start:localhost": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 npm exec -- expo start --localhost --port 8086",
    "android": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 npm exec -- expo start --android --port 8086",
    "ios": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 npm exec -- expo start --ios --port 8086",
    "web": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 npm exec -- expo start --web --port 8086",
    "postinstall": "node ./scripts/ensure-assets.mjs && patch-package --patch-dir ../../patches",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
